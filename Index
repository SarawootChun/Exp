function toggleClaim(id){
  const reports=getReports(); const r=reports.find(x=>x.id===id); if(!r) return;
  r.claim_status=r.claim_status===0?1:0; r.claimed_at=r.claim_status?new Date().toISOString():null;
  lsSave('reports',reports); updateStats(); renderReports();
  toast(r.claim_status?'บันทึก: เคลมแล้ว ✅':'ยกเลิกสถานะเคลมแล้ว');
}
function toggleSentClaim(id){
  const reports=getReports(); const r=reports.find(x=>x.id===id); if(!r) return;
  r.sent_claim=r.sent_claim?0:1; r.sent_at=r.sent_claim?new Date().toISOString():null;
  lsSave('reports',reports); updateStats(); renderReports();
  toast(r.sent_claim?'ส่งเคลมบริษัทแล้ว 📨':'ยกเลิกการส่งเคลม');
}

