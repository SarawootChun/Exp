function compressImg(file,maxPx=900,q=0.72){
  return new Promise(res=>{
    const r=new FileReader();
    r.onload=e=>{
      const img=new Image();
      img.onload=()=>{
        const cv=document.createElement('canvas');
        let w=img.width,h=img.height;
        if(w>maxPx||h>maxPx){const s=Math.min(maxPx/w,maxPx/h);w=Math.round(w*s);h=Math.round(h*s);}
        cv.width=w; cv.height=h;
        cv.getContext('2d').drawImage(img,0,0,w,h);
        res(cv.toDataURL('image/jpeg',q));
      };
      img.src=e.target.result;
    };
    r.readAsDataURL(file);
  });
}
async function handleImg(input,prevId,nameId,plusId,key){
  const file=input.files[0]; if(!file) return;
  const b64=await compressImg(file);
  imgData[key]=b64;
