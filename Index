function editGroup(id){
  const g=getBrandGroups().find(x=>x.id===id); if(!g) return;
  const nameEl=document.getElementById(`group-name-${id}`); if(!nameEl) return;
  nameEl.innerHTML=`
    <input type="text" id="edit-group-inp-${id}" value="${g.name}"
      style="border:1.5px solid #7c3aed;border-radius:.5rem;padding:.25rem .6rem;font-size:.85rem;outline:none;width:100%;max-width:160px"
      onkeydown="if(event.key==='Enter')saveGroupEdit(${id});if(event.key==='Escape')renderGroups()">
    <button onmousedown="saveGroupEdit(${id})" style="font-size:.72rem;color:#7c3aed;font-weight:700;cursor:pointer;background:none;border:none;margin-left:.3rem">💾</button>`;
  const inp=document.getElementById(`edit-group-inp-${id}`);
  if(inp){inp.focus();inp.select();}
}
function saveGroupEdit(id){
  const inp=document.getElementById(`edit-group-inp-${id}`); if(!inp) return;
  const newName=inp.value.trim(); if(!newName) return;
  const gs=getBrandGroups(); const g=gs.find(x=>x.id===id);
  if(g){g.name=newName;lsSave('brandGroups',gs);renderGroups();renderBrands();toast('แก้ไขกลุ่มแล้ว');}
}
function delGroup(id){
  const bs=getBrands();
  bs.forEach(b=>{if(b.group_id===id) b.group_id=null;});
  lsSave('brands',bs);
  lsSave('brandGroups',getBrandGroups().filter(g=>g.id!==id));
  renderGroups(); renderBrands(); toast('ลบกลุ่มแล้ว');
}

// ══════════════════════════════════════════
// SETTINGS — BRANDS
// ══════════════════════════════════════════
function renderBrands(){
  const ul=document.getElementById('brandList'); ul.innerHTML='';
  const groups=getBrandGroups();
  getBrands().forEach(b=>{
    const li=document.createElement('li');
    li.id=`brand-li-${b.id}`;
    li.style.cssText='padding:.65rem 1rem;display:flex;align-items:flex-start;justify-content:space-between;gap:.5rem';
    const groupName=b.group_id?groups.find(g=>g.id===b.group_id)?.name:'';
    let groupOpts=`<option value="">ไม่มีกลุ่ม</option>`;
    groups.forEach(g=>{groupOpts+=`<option value="${g.id}"${b.group_id===g.id?' selected':''}>🗂️ ${g.name}</option>`;});
    li.innerHTML=`
      <div style="min-width:0;flex:1">
        <p id="brand-name-${b.id}" style="font-size:.87rem;font-weight:600;color:#374151;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${b.name}</p>
        ${groupName?`<p style="font-size:.7rem;color:#7c3aed">🗂️ ${groupName}</p>`:'<p style="font-size:.7rem;color:#d1d5db">ไม่มีกลุ่ม</p>'}
        ${groups.length?`<select onchange="assignBrandGroup(${b.id},this.value)" style="font-size:.7rem;border:1px solid #e5e7eb;border-radius:.5rem;padding:.15rem .4rem;background:#f9fafb;cursor:pointer;outline:none;margin-top:.25rem;max-width:9rem">${groupOpts}</select>`:''}
      </div>
      <div style="display:flex;gap:.35rem;align-items:center;flex-shrink:0;flex-wrap:wrap;justify-content:flex-end">
        <span style="font-size:.7rem;padding:.15rem .5rem;border-radius:99px;background:${b.active?'#dcfce7':'#f3f4f6'};color:${b.active?'#15803d':'#9ca3af'}">${b.active?'ใช้':'ปิด'}</span>
        <button onclick="editBrand(${b.id})" style="font-size:.7rem;padding:.2rem .55rem;border-radius:.5rem;background:#e0f2fe;color:#0369a1;font-weight:700;border:none;cursor:pointer">✏️</button>
        <button onclick="toggleBrand(${b.id})" style="font-size:.7rem;padding:.2rem .55rem;border-radius:.5rem;background:${b.active?'#fef9c3':'#dcfce7'};color:${b.active?'#a16207':'#15803d'};font-weight:700;border:none;cursor:pointer">${b.active?'ปิด':'เปิด'}</button>
        <button onclick="delBrand(${b.id})" style="font-size:.7rem;padding:.2rem .55rem;border-radius:.5rem;background:#fee2e2;color:#dc2626;font-weight:700;border:none;cursor:pointer">ลบ</button>
      </div>`;
    ul.appendChild(li);
  });
}
function assignBrandGroup(brandId,groupId){
  const bs=getBrands(); const b=bs.find(x=>x.id===brandId);
  if(b){b.group_id=groupId?parseInt(groupId):null;lsSave('brands',bs);renderBrands();toast('กำหนดกลุ่มแล้ว');}
}
function editBrand(id){
  const b=getBrands().find(x=>x.id===id); if(!b) return;
  const nameEl=document.getElementById(`brand-name-${id}`); if(!nameEl) return;
  nameEl.innerHTML=`
    <input type="text" id="edit-brand-inp-${id}" value="${b.name}"
      style="border:1.5px solid #3b82f6;border-radius:.5rem;padding:.25rem .6rem;font-size:.85rem;outline:none;width:100%;max-width:180px"
      onkeydown="if(event.key==='Enter')saveBrandEdit(${id});if(event.key==='Escape')renderBrands()">
    <button onmousedown="saveBrandEdit(${id})" style="font-size:.72rem;color:#2563eb;font-weight:700;cursor:pointer;background:none;border:none;margin-left:.3rem">💾</button>`;
  const inp=document.getElementById(`edit-brand-inp-${id}`);
  if(inp){inp.focus();inp.select();}
}
function saveBrandEdit(id){
  const inp=document.getElementById(`edit-brand-inp-${id}`); if(!inp) return;
  const newName=inp.value.trim(); if(!newName) return;
  const bs=getBrands(); const b=bs.find(x=>x.id===id);
  if(b){b.name=newName;lsSave('brands',bs);renderBrands();populateFormSelects();toast('แก้ไขแบรนด์แล้ว');}
}
function addBrand(){
  const name=document.getElementById('newBrandName').value.trim();
  if(!name) return toast('กรุณาระบุชื่อแบรนด์','red');
  const bs=getBrands();
  if(bs.find(b=>b.name===name)) return toast('ชื่อนี้มีอยู่แล้ว','red');
  const maxId=bs.length?Math.max(...bs.map(b=>b.id)):0;
  bs.push({id:maxId+1,name,active:true});
  lsSave('brands',bs);
  document.getElementById('newBrandName').value='';
  renderBrands(); populateFormSelects(); toast('เพิ่ม "'+name+'" แล้ว');
}
function toggleBrand(id){const bs=getBrands(),b=bs.find(x=>x.id===id);if(b){b.active=!b.active;lsSave('brands',bs);renderBrands();populateFormSelects();}}
function delBrand(id){lsSave('brands',getBrands().filter(b=>b.id!==id));renderBrands();populateFormSelects();toast('ลบแบรนด์แล้ว');}

// ══════════════════════════════════════════
// TOAST
// ══════════════════════════════════════════
let _tt;
function toast(msg,type='green'){
  const t=document.getElementById('toast');
  document.getElementById('toastIcon').textContent=type==='red'?'❌':'✅';
  document.getElementById('toastMsg').textContent=msg;
  t.style.borderColor=type==='red'?'#fca5a5':'#86efac';
  t.classList.add('show');
  clearTimeout(_tt); _tt=setTimeout(()=>t.classList.remove('show'),3000);
}

// ══════════════════════════════════════════
// INIT
// ══════════════════════════════════════════
populateFormSelects();
</script>
</body>
</html>
