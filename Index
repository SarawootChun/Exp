}

function claimAll(){
  const reports=getReports(); let changed=0;
  reports.forEach(r=>{if(!r.claim_status){r.claim_status=1;r.claimed_at=new Date().toISOString();changed++;}});
  lsSave('reports',reports); updateStats(); renderReports();
  toast(changed?`เคลมแล้ว ${changed} รายการ ✅`:'ทุกรายการเคลมแล้ว');
}
function unclaimAll(){
  const reports=getReports(); let changed=0;
  reports.forEach(r=>{if(r.claim_status){r.claim_status=0;r.claimed_at=null;changed++;}});
  lsSave('reports',reports); updateStats(); renderReports();
  toast(changed?`ยกเลิกเคลม ${changed} รายการแล้ว`:'ไม่มีรายการที่เคลม');
}
function sentClaimAll(){
  const reports=getReports(); let changed=0;
  reports.forEach(r=>{if(!r.sent_claim){r.sent_claim=1;r.sent_at=new Date().toISOString();changed++;}});
  lsSave('reports',reports); updateStats(); renderReports();
  toast(changed?`ส่งเคลมบริษัทแล้ว ${changed} รายการ 📨`:'ทุกรายการส่งแล้ว');
}

function openLB(src){document.getElementById('lbImg').src=src;document.getElementById('lb').style.display='flex';}
function fmtDate(iso){
  if(!iso) return '-';
  const d=new Date(iso);
  return `${d.getDate()} ${THM[d.getMonth()+1]} ${d.getFullYear()+543} ${String(d.getHours()).padStart(2,'0')}:${String(d.getMinutes()).padStart(2,'0')}`;
}

