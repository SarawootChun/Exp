      if(Object.keys(byGroup).some(k=>parseInt(k)>0)){
        const h=document.createElement('div'); h.className='bd-group-hd'; h.textContent='อื่นๆ'; dd.appendChild(h);
      }
      ungrouped.forEach(b=>dd.appendChild(mkItem(b)));
    }
