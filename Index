function filterBrands(){
  const raw=document.getElementById('brandSearch').value||'';
  const q=raw.toLowerCase().trim();
  const allBrands=getBrands().filter(b=>b.active);
  const groups=getBrandGroups();
  const filtered=q?allBrands.filter(b=>b.name.toLowerCase().includes(q)):allBrands;
  const dd=document.getElementById('brandDD');
  dd.innerHTML='';

  function mkItem(b){
    const d=document.createElement('div'); d.className='bd-item';
    if(q){
      const idx=b.name.toLowerCase().indexOf(q);
      d.innerHTML=b.name.substring(0,idx)
        +`<b style="color:#1d4ed8">${b.name.substring(idx,idx+q.length)}</b>`
        +b.name.substring(idx+q.length);
    } else { d.textContent=b.name; }
    d.onmousedown=()=>selectBrand(b.id,b.name);
    return d;
  }

  if(!q && groups.length>0){
    // group display
    const byGroup={};
    filtered.forEach(b=>{ const gId=b.group_id||0; if(!byGroup[gId])byGroup[gId]=[]; byGroup[gId].push(b); });
    groups.forEach(g=>{
      const gBrands=byGroup[g.id]||[];
