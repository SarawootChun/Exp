<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no"/>
<title>ระบบรายงานสินค้าหมดอายุ</title>
<script src="https://cdn.tailwindcss.com"></script>
<link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
*{font-family:'Sarabun',sans-serif;box-sizing:border-box}

.uzone{display:flex;align-items:center;gap:.75rem;border:2.5px dashed;border-radius:.75rem;padding:.85rem 1rem;cursor:pointer;transition:transform .18s,box-shadow .18s;-webkit-tap-highlight-color:transparent}
.uzone:hover{transform:translateY(-2px);box-shadow:0 6px 18px rgba(0,0,0,.1)}
.uzone.done{border-style:solid}
.uzone input[type=file]{position:absolute;width:1px;height:1px;opacity:0;pointer-events:none}

.sbg{display:inline-flex;align-items:center;gap:.4rem;padding:.3rem 1rem;border-radius:99px;font-weight:700;font-size:.93rem}
.sbg-g{background:#dcfce7;color:#15803d;border:2px solid #86efac}
.sbg-r{background:#fee2e2;color:#dc2626;border:2px solid #fca5a5}
.sbg-n{background:#f3f4f6;color:#9ca3af;border:2px solid #e5e7eb}
.dot{width:9px;height:9px;border-radius:50%;display:inline-block}
.dg{background:#16a34a;animation:p 1.8s infinite}
.dr{background:#dc2626;animation:p 1.8s infinite}
@keyframes p{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.4;transform:scale(1.5)}}

.nb{flex:1;padding:.6rem 0;font-size:.78rem;font-weight:600;color:#9ca3af;border-top:3px solid transparent;transition:all .2s;background:none;border-left:none;border-right:none;border-bottom:none;cursor:pointer}
.nb.on{color:#1d4ed8;border-top-color:#1d4ed8}

.bx{display:inline-flex;align-items:center;gap:.2rem;padding:.15rem .6rem;border-radius:99px;font-size:.73rem;font-weight:700}
.bx-r{background:#fee2e2;color:#dc2626}
.bx-g{background:#dcfce7;color:#15803d}
.bx-y{background:#fef9c3;color:#a16207}
.bx-b{background:#dbeafe;color:#1d4ed8}
.bx-p{background:#ede9fe;color:#7c3aed}
.bx-o{background:#fff7ed;color:#c2410c;border:1px solid #fed7aa}

.mbtn{background:linear-gradient(135deg,#1d4ed8,#3b82f6);color:#fff;font-weight:700;transition:all .2s;border:none;cursor:pointer}
.mbtn:hover{transform:translateY(-1px);box-shadow:0 6px 18px rgba(59,130,246,.4)}
.mbtn:disabled{background:#9ca3af;cursor:not-allowed;transform:none;box-shadow:none}

.card{background:#fff;border-radius:1rem;padding:1rem;box-shadow:0 1px 3px rgba(0,0,0,.08);border:1px solid #f3f4f6}

#lb{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.9);z-index:9990;display:none;align-items:center;justify-content:center}
#lb img{max-width:96vw;max-height:90vh;border-radius:.8rem}

#toast{position:fixed;bottom:5.5rem;left:50%;z-index:9999;min-width:14rem;transform:translateX(-50%) translateY(6rem);transition:transform .3s cubic-bezier(.34,1.56,.64,1)}
#toast.show{transform:translateX(-50%) translateY(0)}

/* chip filters */
.chip{display:inline-flex;align-items:center;padding:.28rem .7rem;border-radius:99px;font-size:.74rem;font-weight:600;cursor:pointer;border:1.5px solid #e5e7eb;background:#f9fafb;color:#6b7280;transition:all .15s;white-space:nowrap;user-select:none;-webkit-user-select:none;-webkit-tap-highlight-color:transparent}
.chip:hover{border-color:#93c5fd;color:#1d4ed8}
.chip.on{background:#dbeafe;border-color:#60a5fa;color:#1d4ed8}
.chip-row{display:flex;flex-wrap:wrap;gap:.4rem}

/* brand combobox dropdown */
#brandDD{display:none;position:absolute;left:0;right:0;top:calc(100% + 4px);background:#fff;border:1.5px solid #e5e7eb;border-radius:.75rem;box-shadow:0 8px 24px rgba(0,0,0,.13);z-index:300;overflow:hidden;max-height:14rem;overflow-y:auto}
.bd-item{padding:.5rem 1rem;font-size:.85rem;cursor:pointer;color:#374151;transition:background .12s}
.bd-item:hover,.bd-item:active{background:#eff6ff}
.bd-group-hd{padding:.28rem 1rem .1rem;font-size:.68rem;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.04em;background:#f9fafb;border-top:1px solid #f3f4f6}
.bd-add{padding:.5rem 1rem;font-size:.85rem;cursor:pointer;color:#2563eb;font-weight:700;border-top:1px solid #e5e7eb;background:#f0f9ff;transition:background .12s}
.bd-add:hover,.bd-add:active{background:#dbeafe}

/* confirm modal */
#confirmModal{position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:9995;display:none;align-items:center;justify-content:center;padding:1rem}

select,input,textarea{appearance:none;-webkit-appearance:none}
</style>
</head>
<body class="bg-gray-50 min-h-screen">

<!-- ═══ HEADER ═══ -->
<header class="bg-white shadow-sm sticky top-0 z-40">
  <div class="max-w-lg mx-auto px-4 py-2.5 flex items-center justify-between">
    <div class="flex items-center gap-2">
      <div class="w-9 h-9 bg-blue-600 rounded-xl flex items-center justify-center text-xl">📦</div>
      <div>
        <div id="headerTitle" class="font-bold text-gray-800 text-sm leading-tight">แจ้งสินค้าหมดอายุ</div>
        <div id="clock" class="text-xs text-gray-400">--:--:--</div>
      </div>
    </div>
    <div id="adminBadge" style="display:none" class="bg-blue-50 border border-blue-200 rounded-xl px-3 py-1 flex items-center gap-1.5">
      <span class="w-2 h-2 bg-blue-500 rounded-full inline-block"></span>
      <span class="text-xs font-semibold text-blue-700">Admin</span>
      <button onclick="logout()" style="margin-left:.25rem;color:#9ca3af;font-weight:700;background:none;border:none;cursor:pointer;font-size:.9rem">✕</button>
    </div>
  </div>
</header>

<!-- ═══ BOTTOM NAV ═══ -->
<nav class="fixed bottom-0 left-0 right-0 bg-white border-t border-gray-200 z-40 flex">
  <button class="nb on" id="nb-user"      onclick="goTo('user')">      <div class="text-xl">📤</div><div>ส่งรายงาน</div></button>
  <button class="nb"    id="nb-dashboard" onclick="goTo('dashboard')"> <div class="text-xl">📊</div><div>Admin</div></button>
  <button class="nb"    id="nb-settings"  onclick="goTo('settings')">  <div class="text-xl">⚙️</div><div>ตั้งค่า</div></button>
</nav>

<!-- ════════════════════════════════════════
     VIEW 1 : USER FORM
════════════════════════════════════════════ -->
<div id="v-user" class="max-w-lg mx-auto px-4 pt-4 pb-36 space-y-4">

  <!-- รูปภาพ -->
  <div class="card">
    <p class="text-sm font-bold text-gray-700 mb-3">🖼️ รูปภาพประกอบ <span class="text-xs font-normal text-gray-400">คลิกเพื่อถ่าย/เลือกรูป</span></p>
    <div class="space-y-3">
      <label for="inp1" class="uzone border-blue-300 bg-blue-50">
        <input type="file" id="inp1" accept="image/*" capture="environment" onchange="handleImg(this,'prev1','name1','plus1','i1')">
        <div id="prev1" class="w-16 h-16 rounded-xl bg-blue-100 flex items-center justify-center text-3xl flex-shrink-0 overflow-hidden">📦</div>
        <div class="flex-1 min-w-0">
          <p class="font-semibold text-sm text-gray-700">ภาพหน้าสินค้า</p>
          <p class="text-xs text-gray-400 mt-0.5">ถ่ายให้เห็นชื่อสินค้าชัดเจน</p>
          <p id="name1" class="text-xs text-blue-600 mt-1 truncate" style="display:none"></p>
        </div>
        <span id="plus1" class="text-blue-400 text-2xl flex-shrink-0">＋</span>
      </label>
      <label for="inp2" class="uzone border-green-300 bg-green-50">
        <input type="file" id="inp2" accept="image/*" capture="environment" onchange="handleImg(this,'prev2','name2','plus2','i2')">
        <div id="prev2" class="w-16 h-16 rounded-xl bg-green-100 flex items-center justify-center text-3xl flex-shrink-0 overflow-hidden">📊</div>
        <div class="flex-1 min-w-0">
          <p class="font-semibold text-sm text-gray-700">ภาพรวมจำนวนสินค้า</p>
          <p class="text-xs text-gray-400 mt-0.5">ถ่ายให้เห็นปริมาณสินค้าทั้งหมด</p>
          <p id="name2" class="text-xs text-green-600 mt-1 truncate" style="display:none"></p>
        </div>
        <span id="plus2" class="text-green-400 text-2xl flex-shrink-0">＋</span>
      </label>
      <label for="inp3" class="uzone border-orange-300 bg-orange-50">
        <input type="file" id="inp3" accept="image/*" capture="environment" onchange="handleImg(this,'prev3','name3','plus3','i3')">
        <div id="prev3" class="w-16 h-16 rounded-xl bg-orange-100 flex items-center justify-center text-3xl flex-shrink-0 overflow-hidden">📅</div>
        <div class="flex-1 min-w-0">
          <p class="font-semibold text-sm text-gray-700">ภาพเลขวันหมดอายุ</p>
          <p class="text-xs text-gray-400 mt-0.5">ถ่ายให้เห็นวันหมดอายุบนบรรจุภัณฑ์</p>
          <p id="name3" class="text-xs text-orange-600 mt-1 truncate" style="display:none"></p>
        </div>
        <span id="plus3" class="text-orange-400 text-2xl flex-shrink-0">＋</span>
      </label>
    </div>
  </div>

  <!-- ข้อมูลพื้นฐาน -->
  <div class="card space-y-4">
    <p class="text-sm font-bold text-gray-700">ℹ️ ข้อมูลพื้นฐาน</p>
    <div>
      <label class="block text-xs font-semibold text-gray-500 mb-1.5">👤 ชื่อผู้รายงาน <span class="text-red-500">*</span></label>
      <input id="reporterName" type="text" placeholder="ชื่อ-นามสกุล ผู้รายงาน"
        class="w-full border border-gray-200 rounded-xl px-3.5 py-2.5 text-sm bg-gray-50" style="outline:none"
        oninput="localStorage.setItem('reporterName',this.value)">
    </div>
    <div>
      <label class="block text-xs font-semibold text-gray-500 mb-1.5">📍 สาขา <span class="text-red-500">*</span></label>
      <select id="branchSel" class="w-full border border-gray-200 rounded-xl px-3.5 py-2.5 text-sm bg-gray-50" style="outline:none">
        <option value="">— เลือกสาขา —</option>
      </select>
    </div>
    <div>
      <label class="block text-xs font-semibold text-gray-500 mb-1.5">🏷️ แบรนด์สินค้า <span class="text-red-500">*</span></label>
      <div style="position:relative">
        <input id="brandSearch" type="text" placeholder="ค้นหาหรือพิมพ์ชื่อแบรนด์..." autocomplete="off"
          class="w-full border border-gray-200 rounded-xl px-3.5 py-2.5 text-sm bg-gray-50" style="outline:none"
          oninput="filterBrands()" onfocus="openBrandDD()" onblur="setTimeout(closeBrandDD,220)">
        <input type="hidden" id="brandId" value="">
        <div id="brandDD"></div>
      </div>
      <p class="text-xs text-gray-400 mt-1">💡 พิมพ์ชื่อใหม่แล้วกด "เพิ่มแบรนด์" เพื่อสร้างทันที</p>
    </div>
    <div>
      <label class="block text-xs font-semibold text-gray-500 mb-1.5">📅 วัน/เดือน/ปี หมดอายุ <span class="text-red-500">*</span></label>
      <div class="grid grid-cols-3 gap-2">
        <select id="expiryD" onchange="updateStatus()" class="border border-gray-200 rounded-xl px-2 py-2.5 text-sm bg-gray-50" style="outline:none">
          <option value="">วันที่</option>
        </select>
        <select id="expiryM" onchange="updateStatus()" class="border border-gray-200 rounded-xl px-2 py-2.5 text-sm bg-gray-50" style="outline:none">
          <option value="">เดือน</option>
          <option value="1">ม.ค.</option><option value="2">ก.พ.</option>
          <option value="3">มี.ค.</option><option value="4">เม.ย.</option>
          <option value="5">พ.ค.</option><option value="6">มิ.ย.</option>
          <option value="7">ก.ค.</option><option value="8">ส.ค.</option>
          <option value="9">ก.ย.</option><option value="10">ต.ค.</option>
          <option value="11">พ.ย.</option><option value="12">ธ.ค.</option>
        </select>
        <select id="expiryY" onchange="updateStatus()" class="border border-gray-200 rounded-xl px-2 py-2.5 text-sm bg-gray-50" style="outline:none">
          <option value="">ปี พ.ศ.</option>
        </select>
      </div>
    </div>
  </div>

  <!-- สถานะ -->
  <div class="card">
    <p class="text-xs font-semibold text-gray-400 mb-2">สถานะสินค้า</p>
    <div id="statusDisplay"><span class="sbg sbg-n"><span class="dot bg-gray-300"></span>กรุณาระบุวันหมดอายุ</span></div>
  </div>

  <!-- หมายเหตุ -->
  <div class="card">
    <label class="block text-xs font-semibold text-gray-500 mb-1.5">📝 หมายเหตุ (ไม่บังคับ)</label>
    <textarea id="noteInp" rows="2" placeholder="รายละเอียดเพิ่มเติม เช่น จำนวนชิ้น ล็อตสินค้า"
      class="w-full border border-gray-200 rounded-xl px-3.5 py-2.5 text-sm bg-gray-50 resize-none" style="outline:none"></textarea>
  </div>

  <button id="submitBtn" onclick="submitReport()" class="mbtn w-full py-4 rounded-2xl text-base shadow-md">📤 ส่งรายงาน</button>

  <div id="successMsg" style="display:none" class="bg-green-50 border-2 border-green-300 rounded-2xl p-6 text-center">
    <div class="text-5xl mb-3">✅</div>
    <p class="font-black text-green-700 text-lg">ส่งรายงานสำเร็จ!</p>
    <p class="text-green-600 text-sm mt-1 mb-4">ทีมงานได้รับข้อมูลเรียบร้อย</p>
    <button onclick="resetForm()" class="mbtn px-6 py-2.5 rounded-xl text-sm">➕ ส่งรายงานใหม่</button>
  </div>
</div>

<!-- ════════════════════════════════════════
     VIEW 2 : ADMIN DASHBOARD
════════════════════════════════════════════ -->
<div id="v-dashboard" class="max-w-lg mx-auto px-4 pt-4 pb-36 space-y-4" style="display:none">

  <!-- LOGIN -->
  <div id="loginSection" class="card text-center py-8">
    <div class="w-20 h-20 bg-blue-600 rounded-2xl flex items-center justify-center mx-auto mb-4 text-4xl">🔐</div>
    <h2 class="font-black text-xl text-gray-800">Admin Login</h2>
    <p class="text-sm text-gray-400 mb-6">ระบบหลังบ้านสำหรับผู้ดูแล</p>
    <div class="space-y-3 text-left max-w-xs mx-auto">
      <div>
        <label class="block text-xs font-semibold text-gray-500 mb-1">Username</label>
        <input id="loginUser" type="text" value="admin" autocomplete="username"
          class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm bg-gray-50" style="outline:none"
          onkeydown="if(event.key==='Enter')document.getElementById('loginPass').focus()">
      </div>
      <div>
        <label class="block text-xs font-semibold text-gray-500 mb-1">Password</label>
        <input id="loginPass" type="password" placeholder="รหัสผ่าน" autocomplete="current-password"
          class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm bg-gray-50" style="outline:none"
          onkeydown="if(event.key==='Enter')doLogin()">
      </div>
      <p id="loginErr" style="display:none" class="text-red-500 text-sm text-center font-semibold">❌ รหัสผ่านไม่ถูกต้อง</p>
      <button onclick="doLogin()" class="w-full bg-blue-600 text-white font-bold py-3 rounded-xl text-base" style="border:none;cursor:pointer">🔓 เข้าสู่ระบบ</button>
    </div>
    <div class="mt-5 p-3 bg-gray-50 rounded-xl max-w-xs mx-auto">
      <p class="text-xs text-gray-400">รหัสเริ่มต้น</p>
      <p class="text-sm font-bold text-gray-600">admin / admin1234</p>
      <button onclick="resetToDefault()" class="text-xs text-blue-500 mt-1" style="background:none;border:none;cursor:pointer">🔄 รีเซ็ตรหัสผ่านเป็นค่าเริ่มต้น</button>
    </div>
  </div>

  <!-- DASHBOARD -->
  <div id="dashSection" style="display:none" class="space-y-4">

    <!-- stats -->
    <div class="grid grid-cols-2 gap-3">
      <div class="card"><p class="text-xs text-gray-400">รายงานทั้งหมด</p><p id="st-total" class="text-3xl font-black text-gray-800">0</p></div>
      <div class="card"><p class="text-xs text-gray-400">หมดอายุแล้ว</p><p id="st-exp" class="text-3xl font-black text-red-600">0</p></div>
      <div class="card"><p class="text-xs text-gray-400">เคลมแล้ว</p><p id="st-claimed" class="text-3xl font-black text-green-600">0</p></div>
      <div class="bg-purple-50 rounded-2xl p-4 border border-purple-100">
        <p class="text-xs text-purple-400">📨 รอเคลม (ส่งแล้ว)</p>
        <p id="st-wait" class="text-3xl font-black text-purple-700">0</p>
      </div>
    </div>

    <!-- bulk actions -->
    <div class="card">
      <p class="text-xs font-semibold text-gray-400 mb-2.5">⚡ การดำเนินการ</p>
      <div class="flex gap-2 flex-wrap">
        <button onclick="downloadAllImages()"
          style="display:flex;align-items:center;gap:.3rem;padding:.45rem .85rem;border-radius:.7rem;background:#eff6ff;color:#1d4ed8;font-size:.78rem;font-weight:700;border:1.5px solid #bfdbfe;cursor:pointer">
          📥 ดาวน์โหลดรูปทั้งหมด
        </button>
        <button onclick="confirmClaimAll()"
          style="display:flex;align-items:center;gap:.3rem;padding:.45rem .85rem;border-radius:.7rem;background:#f0fdf4;color:#15803d;font-size:.78rem;font-weight:700;border:1.5px solid #86efac;cursor:pointer">
          ✅ เคลมแล้วทั้งหมด
        </button>
        <button onclick="confirmUnclaimAll()"
          style="display:flex;align-items:center;gap:.3rem;padding:.45rem .85rem;border-radius:.7rem;background:#fff7ed;color:#c2410c;font-size:.78rem;font-weight:700;border:1.5px solid #fdba74;cursor:pointer">
          ↩ ยกเลิกเคลมทั้งหมด
        </button>
        <button onclick="confirmSentClaimAll()"
          style="display:flex;align-items:center;gap:.3rem;padding:.45rem .85rem;border-radius:.7rem;background:#faf5ff;color:#7c3aed;font-size:.78rem;font-weight:700;border:1.5px solid #c4b5fd;cursor:pointer">
          📨 ส่งเคลมบริษัท (ทั้งหมด)
        </button>
      </div>
      <!-- download month/year filter -->
      <div style="margin-top:.75rem;padding-top:.75rem;border-top:1px solid #f3f4f6">
        <p class="text-xs text-gray-400 mb-1.5">📅 กรองเดือน/ปี หมดอายุ สำหรับดาวน์โหลด</p>
        <div class="flex gap-2 items-center flex-wrap">
          <select id="dl-month" class="border border-gray-200 rounded-xl px-2.5 py-1.5 text-xs bg-gray-50" style="outline:none">
            <option value="">ทุกเดือน</option>
            <option value="1">ม.ค.</option><option value="2">ก.พ.</option><option value="3">มี.ค.</option>
            <option value="4">เม.ย.</option><option value="5">พ.ค.</option><option value="6">มิ.ย.</option>
            <option value="7">ก.ค.</option><option value="8">ส.ค.</option><option value="9">ก.ย.</option>
            <option value="10">ต.ค.</option><option value="11">พ.ย.</option><option value="12">ธ.ค.</option>
          </select>
          <select id="dl-year" class="border border-gray-200 rounded-xl px-2.5 py-1.5 text-xs bg-gray-50" style="outline:none">
            <option value="">ทุกปี</option>
          </select>
          <button onclick="downloadFilteredImages()"
            style="padding:.4rem .85rem;border-radius:.7rem;background:#1d4ed8;color:#fff;font-size:.75rem;font-weight:700;border:none;cursor:pointer">
            📥 ดาวน์โหลด
          </button>
        </div>
      </div>
    </div>

    <!-- chip filters -->
    <div class="card space-y-3">
      <p class="text-xs font-semibold text-gray-500">🔍 กรองข้อมูล</p>
      <div>
        <p class="text-xs text-gray-400 mb-1.5">📍 สาขา <span class="text-gray-300">(เลือกได้หลายสาขา)</span></p>
        <div id="chip-branch" class="chip-row"></div>
      </div>
      <div>
        <p class="text-xs text-gray-400 mb-1.5">🏷️ แบรนด์ <span class="text-gray-300">(เลือกได้หลายแบรนด์)</span></p>
        <div id="chip-brand" class="chip-row"></div>
      </div>
      <div>
        <p class="text-xs text-gray-400 mb-1.5">📋 สถานะเคลม</p>
        <div id="chip-claim-row" class="chip-row"></div>
      </div>
      <div>
        <p class="text-xs text-gray-400 mb-1.5">📅 สถานะหมดอายุ</p>
