async function submitReport(){
  const reporter=document.getElementById('reporterName').value.trim();
  const bId=parseInt(document.getElementById('branchSel').value);
  const brId=parseInt(document.getElementById('brandId').value);
  const brName=document.getElementById('brandSearch').value.trim();
  const d=parseInt(document.getElementById('expiryD').value)||null;
  const m=parseInt(document.getElementById('expiryM').value);
  const y=parseInt(document.getElementById('expiryY').value);
  if(!reporter) return toast('กรุณาระบุชื่อผู้รายงาน','red');
  if(!bId)      return toast('กรุณาเลือกสาขา','red');
  if(!brId)     return toast('กรุณาเลือกแบรนด์','red');
  if(!m)        return toast('กรุณาเลือกเดือนหมดอายุ','red');
  if(!y)        return toast('กรุณาเลือกปีหมดอายุ','red');
  if(!imgData.i1&&!imgData.i2&&!imgData.i3) return toast('กรุณาอัพโหลดรูปภาพอย่างน้อย 1 รูป','red');
  localStorage.setItem('reporterName',reporter);
  const btn=document.getElementById('submitBtn');
  btn.disabled=true; btn.textContent='⏳ กำลังบันทึก...';
  await new Promise(r=>setTimeout(r,300));
  const branch=getBranches().find(b=>b.id===bId);
  const brand=getBrands().find(b=>b.id===brId);
  const exp=isExpiredFn(m,y);
  const reports=getReports();
  const maxId=reports.length?Math.max(...reports.map(r=>r.id)):0;
  reports.unshift({
    id:maxId+1, reporter_name:reporter,
    branch_id:bId, branch_name:branch?.name||'',
    brand_id:brId, brand_name:brand?.name||brName,
    expiry_day:d, expiry_month:m, expiry_year:y, is_expired:exp,
    i1:imgData.i1, i2:imgData.i2, i3:imgData.i3,
    note:document.getElementById('noteInp').value.trim(),
    claim_status:0, claimed_at:null,
    sent_claim:0,   sent_at:null,
    submitted_at:new Date().toISOString(),
  });
  lsSave('reports',reports);
  btn.disabled=false; btn.textContent='📤 ส่งรายงาน';
  document.getElementById('successMsg').style.display='block';
  document.getElementById('successMsg').scrollIntoView({behavior:'smooth'});
}

function resetForm(){
  document.getElementById('successMsg').style.display='none';
  document.getElementById('reporterName').value=localStorage.getItem('reporterName')||'';
  ['branchSel','expiryD','expiryM','expiryY','noteInp'].forEach(id=>{document.getElementById(id).value='';});
  document.getElementById('brandSearch').value='';
  document.getElementById('brandSearch').style.borderColor='';
  document.getElementById('brandId').value='';
  imgData={i1:null,i2:null,i3:null};
  [['prev1','📦','inp1','name1','plus1'],['prev2','📊','inp2','name2','plus2'],['prev3','📅','inp3','name3','plus3']].forEach(([pv,em,ip,nm,pl])=>{
