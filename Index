// ══════════════════════════════════════════
// COMPOSITE IMAGE — รวม 3 รูป เป็น 1:1
// ══════════════════════════════════════════
function buildComposite(srcs){
  return new Promise(resolve=>{
    const SIZE=600;
    const cv=document.createElement('canvas');
    cv.width=SIZE; cv.height=SIZE;
    const ctx=cv.getContext('2d');
    ctx.fillStyle='#f1f5f9'; ctx.fillRect(0,0,SIZE,SIZE);
    const validSrcs=(srcs||[]).filter(Boolean);
    if(!validSrcs.length){resolve(null);return;}
    Promise.all(validSrcs.map(src=>new Promise(r=>{
      const img=new Image(); img.onload=()=>r(img); img.onerror=()=>r(null); img.src=src;
    }))).then(imgs=>{
      const vi=imgs.filter(Boolean);
      if(!vi.length){resolve(null);return;}
      const n=vi.length;
      function drawCover(img,x,y,w,h){
        const ir=img.width/img.height,br=w/h; let sx,sy,sw,sh;
        if(ir>br){sh=img.height;sw=sh*br;sx=(img.width-sw)/2;sy=0;}
        else{sw=img.width;sh=sw/br;sx=0;sy=(img.height-sh)/2;}
        ctx.drawImage(img,sx,sy,sw,sh,x,y,w,h);
      }
      const H=SIZE,W=SIZE,half=Math.floor(W/2),gap=2;
      if(n===1){drawCover(vi[0],0,0,W,H);}
      else if(n===2){
        drawCover(vi[0],0,0,half-gap,H); drawCover(vi[1],half+gap,0,W-half-gap,H);
        ctx.fillStyle='#fff'; ctx.fillRect(half-gap,0,gap*2,H);
      } else {
        drawCover(vi[0],0,0,half-gap,H);
        drawCover(vi[1],half+gap,0,W-half-gap,Math.floor(H/2)-gap);
        drawCover(vi[2],half+gap,Math.floor(H/2)+gap,W-half-gap,H-Math.floor(H/2)-gap);
        ctx.fillStyle='#fff';
        ctx.fillRect(half-gap,0,gap*2,H);
        ctx.fillRect(half,Math.floor(H/2)-gap,W-half,gap*2);
      }
      resolve(cv.toDataURL('image/jpeg',0.9));
    });
  });
}

async function downloadComposite(reportId){
  const rep=getReports().find(r=>r.id===reportId); if(!rep) return;
  toast('กำลังสร้างรูปรวม...');
  const dataURL=await buildComposite([rep.i1,rep.i2,rep.i3]);
  if(!dataURL){toast('ไม่มีรูปภาพในรายการนี้','red');return;}
  const safeName=(rep.branch_name||'report').replace(/\s+/g,'_');
  const a=document.createElement('a'); a.href=dataURL; a.download=`claim_${safeName}_${reportId}.jpg`; a.click();
  toast('ดาวน์โหลดสำเร็จ ✅');
}

async function _batchDownload(reports){
  if(!reports.length){toast('ไม่มีรายการที่ตรงกัน','red');return;}
  toast(`กำลังสร้าง ${reports.length} รูปรวม...`);
  for(let i=0;i<reports.length;i++){
    const rep=reports[i];
    const dataURL=await buildComposite([rep.i1,rep.i2,rep.i3]);
    if(!dataURL) continue;
    await new Promise(res=>setTimeout(res,120));
    const a=document.createElement('a');
    const safeName=(rep.branch_name||'report').replace(/\s+/g,'_');
    a.href=dataURL; a.download=`claim_${String(i+1).padStart(2,'0')}_${safeName}.jpg`; a.click();
    await new Promise(res=>setTimeout(res,280));
  }
  toast(`ดาวน์โหลดครบ ${reports.length} รายการ ✅`);
}

async function downloadAllImages(){await _batchDownload(getReports());}

async function downloadFilteredImages(){
  const dlM=document.getElementById('dl-month').value;
  const dlY=document.getElementById('dl-year').value;
  let r=getReports();
  if(dlM) r=r.filter(x=>String(x.expiry_month)===dlM);
  if(dlY) r=r.filter(x=>String(x.expiry_year)===dlY);
  await _batchDownload(r);
}

