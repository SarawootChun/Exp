// ══════════════════════════════════════════
// CHIP FILTERS — build
// ══════════════════════════════════════════
function buildChips(){
  // ── branch chips ──
  const bc=document.getElementById('chip-branch');
  bc.innerHTML='';
  const allBranchBtn=_chip('ทั้งหมด', chipBranches.size===0);
  allBranchBtn.onclick=()=>{chipBranches.clear();buildChips();renderReports();};
  bc.appendChild(allBranchBtn);
  getBranches().filter(b=>b.active).forEach(b=>{
    const label=b.name.replace('สาขา','');
    const btn=_chip(label, chipBranches.has(b.id));
    btn.title=b.name;
    btn.onclick=()=>{
      chipBranches.has(b.id)?chipBranches.delete(b.id):chipBranches.add(b.id);
      buildChips(); renderReports();
    };
    bc.appendChild(btn);
  });

  // ── brand chips ──
  const brc=document.getElementById('chip-brand');
  brc.innerHTML='';
  const allBrandBtn=_chip('ทั้งหมด', chipBrands.size===0);
  allBrandBtn.onclick=()=>{chipBrands.clear();buildChips();renderReports();};
  brc.appendChild(allBrandBtn);
  getBrands().filter(b=>b.active).forEach(b=>{
    const shortName=b.name.includes('(')?b.name.split('(')[1].replace(')',''):b.name;
    const btn=_chip(shortName, chipBrands.has(b.id));
    btn.title=b.name;
    btn.onclick=()=>{
      chipBrands.has(b.id)?chipBrands.delete(b.id):chipBrands.add(b.id);
      buildChips(); renderReports();
    };
    brc.appendChild(btn);
  });

  // ── claim chips ──
  const cc=document.getElementById('chip-claim-row');
  cc.innerHTML='';
  [['','ทั้งหมด'],['0','⏳ รอดำเนินการ'],['1','✅ เคลมแล้ว'],['sent','📨 ส่งเคลมแล้ว']].forEach(([v,lbl])=>{
    const btn=_chip(lbl, chipClaim===v);
    btn.onclick=()=>{chipClaim=v;buildChips();renderReports();};
    cc.appendChild(btn);
  });

  // ── expiry chips ──
  const ec=document.getElementById('chip-exp-row');
  ec.innerHTML='';
  [['','ทั้งหมด'],['1','🔴 หมดอายุ'],['0','🟢 ยังไม่หมดอายุ']].forEach(([v,lbl])=>{
    const btn=_chip(lbl, chipExp===v);
    btn.onclick=()=>{chipExp=v;buildChips();renderReports();};
    ec.appendChild(btn);
  });
}
function _chip(label,isOn){
  const btn=document.createElement('button');
  btn.className='chip'+(isOn?' on':'');
  btn.textContent=label;
  return btn;
}

// ══════════════════════════════════════════
// RENDER REPORTS
// ══════════════════════════════════════════
function renderReports(){
  let r=getReports();
  if(chipBranches.size>0) r=r.filter(x=>chipBranches.has(x.branch_id));
  if(chipBrands.size>0)   r=r.filter(x=>chipBrands.has(x.brand_id));
  if(chipClaim==='0')    r=r.filter(x=>x.claim_status===0);
  if(chipClaim==='1')    r=r.filter(x=>x.claim_status===1);
  if(chipClaim==='sent') r=r.filter(x=>x.sent_claim===1);
  if(chipExp==='1')      r=r.filter(x=>x.is_expired);
  if(chipExp==='0')      r=r.filter(x=>!x.is_expired);

  const list=document.getElementById('reportList');
  const empty=document.getElementById('emptyMsg');
  list.innerHTML='';
  if(!r.length){empty.style.display='block';return;}
  empty.style.display='none';

  r.forEach(rep=>{
    const expD=rep.expiry_day?`${rep.expiry_day} `:'';
    const expLabel=`${expD}${THM[rep.expiry_month]} ${rep.expiry_year+543}`;
    const expB=rep.is_expired?'<span class="bx bx-r">🔴 หมดอายุ</span>':'<span class="bx bx-g">🟢 ยังไม่หมดอายุ</span>';
    const clB=rep.claim_status?'<span class="bx bx-b">✅ เคลมแล้ว</span>':'<span class="bx bx-y">⏳ รอดำเนินการ</span>';

    // sent_claim → แสดง "ส่งเคลมบริษัทแล้ว" + ถ้ายังไม่ claim ให้แสดง "รอเคลม"
    let sentBadges='';
    if(rep.sent_claim){
      sentBadges='<span class="bx bx-p">📨 ส่งเคลมบริษัทแล้ว</span>';
      if(!rep.claim_status) sentBadges+=' <span class="bx bx-o">⏳ รอเคลม</span>';
    }

    const clBtn=rep.claim_status
      ?`<button onclick="toggleClaim(${rep.id})" style="font-size:.75rem;padding:.3rem .8rem;border-radius:.7rem;background:#f3f4f6;color:#374151;font-weight:700;border:none;cursor:pointer">↩ ยกเลิก</button>`
      :`<button onclick="toggleClaim(${rep.id})" style="font-size:.75rem;padding:.3rem .8rem;border-radius:.7rem;background:#22c55e;color:#fff;font-weight:700;border:none;cursor:pointer">✓ เคลมแล้ว</button>`;
    const sentBtn=rep.sent_claim
      ?`<button onclick="toggleSentClaim(${rep.id})" style="font-size:.75rem;padding:.3rem .8rem;border-radius:.7rem;background:#f3f4f6;color:#7c3aed;font-weight:700;border:none;cursor:pointer">↩ ยกเลิกส่ง</button>`
      :`<button onclick="toggleSentClaim(${rep.id})" style="font-size:.75rem;padding:.3rem .8rem;border-radius:.7rem;background:#7c3aed;color:#fff;font-weight:700;border:none;cursor:pointer">📨 ส่งเคลมบริษัท</button>`;

    const reporterHtml=rep.reporter_name
      ?`<span style="font-size:.72rem;color:#6b7280;display:flex;align-items:center;gap:.2rem">👤 ${rep.reporter_name}</span>`:'';

    const card=document.createElement('div');
    card.className='card';
    card.style.cssText='display:flex;flex-direction:column;gap:.65rem';
    card.innerHTML=`
      <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:.5rem">
        <div style="min-width:0;flex:1">
          <p style="font-weight:700;font-size:.9rem;color:#1f2937;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${rep.branch_name}</p>
          <p style="font-size:.75rem;color:#9ca3af">${rep.brand_name}</p>
          ${reporterHtml}
        </div>
        <div style="display:flex;flex-direction:column;align-items:flex-end;gap:.2rem;flex-shrink:0">
          ${expB}
          <span style="font-size:.72rem;color:#9ca3af">${expLabel}</span>
        </div>
      </div>
      <div id="comp-${rep.id}" style="width:100%;aspect-ratio:1/1;background:#f1f5f9;border-radius:.85rem;overflow:hidden;display:flex;align-items:center;justify-content:center;color:#9ca3af;font-size:.8rem">
        ⏳ กำลังโหลดรูป...
      </div>
      <button onclick="downloadComposite(${rep.id})"
        style="width:100%;padding:.5rem;border-radius:.7rem;background:#eff6ff;color:#1d4ed8;font-size:.8rem;font-weight:700;border:1.5px solid #bfdbfe;cursor:pointer">
        📥 ดาวน์โหลดรูปรวม (สำหรับแจ้งเคลม)
      </button>
      ${rep.note?`<p style="font-size:.78rem;color:#6b7280;background:#f9fafb;border-radius:.6rem;padding:.4rem .7rem">📝 ${rep.note}</p>`:''}
      <div style="display:flex;justify-content:space-between;align-items:center;border-top:1px solid #f3f4f6;padding-top:.5rem">
        <div>${clB}${rep.claimed_at?`<p style="font-size:.7rem;color:#9ca3af;margin-top:.1rem">เคลม: ${fmtDate(rep.claimed_at)}</p>`:''}</div>
        ${clBtn}
      </div>
      <div style="display:flex;justify-content:space-between;align-items:center">
        <div>${sentBadges}${rep.sent_at?`<p style="font-size:.7rem;color:#9ca3af;margin-top:.1rem">ส่ง: ${fmtDate(rep.sent_at)}</p>`:''}</div>
        ${sentBtn}
      </div>
      <p style="font-size:.7rem;color:#d1d5db">ส่งเมื่อ ${fmtDate(rep.submitted_at)}</p>
    `;
    list.appendChild(card);

    buildComposite([rep.i1,rep.i2,rep.i3]).then(dataURL=>{
      const el=document.getElementById(`comp-${rep.id}`);
      if(!el) return;
      if(!dataURL){el.innerHTML='<span style="color:#d1d5db">ไม่มีรูปภาพ</span>';return;}
      el.innerHTML=`<img src="${dataURL}" onclick="openLB('${dataURL}')"
        style="width:100%;height:100%;object-fit:cover;cursor:zoom-in" title="คลิกเพื่อขยาย">`;
    });
  });
}

